# config.bu
variant: fcos
version: 1.7.0
passwd:
  users:
    - name: core
      ssh_authorized_keys:
        - ssh-rsa 

storage:
  files:
    - path: /etc/hostname
      mode: 0644
      overwrite: true
      contents:
        inline: QuickSilver
    - path: /etc/systemd/logind.conf.d/inhibit-suspend.conf
      mode: 0644 
      contents:
        inline: |
          [Login]
          HandleLidSwitch=ignore
